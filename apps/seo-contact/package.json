{
  "name": "seo-contact",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "pnpm exec dotenvx decrypt -f ../../.env --stdout > .env.local && node -e \"const fs=require('node:fs'); const p='../../.env.local'; if (fs.existsSync(p)) fs.appendFileSync('.env.local', fs.readFileSync(p));\" && pnpm cf-typegen && pnpm with-env-local vite",
    "dev:simple": "pnpm exec vite",
    "build:local": "pnpm with-env-local vite build",
    "build:preview": "pnpm with-env-preview vite build",
    "build:production": "pnpm with-env-production vite build",
    "serve:local": "pnpm with-env-local vite preview",
    "test": "vitest run",
    "clean": "git clean -xdf .turbo node_modules dist .cache .wrangler",
    "format": "pnpx @biomejs/biome format . --write",
    "lint": "pnpx @biomejs/biome lint . --write",
    "typecheck": "pnpm cf-typegen && pnpm tsc --noEmit --emitDeclarationOnly false",
    "with-env-local": "pnpm exec dotenvx run -f ../../.env.local -f ../../.env -- ",
    "with-env-preview": "pnpm exec dotenvx run -f ../../.env -- ",
    "with-env-production": "pnpm exec dotenvx run -f ../../.env.production -- ",
    "wrangler": "wrangler",
    "cf-typegen": "pnpm exec wrangler types --env-interface Env"
  },
  "dependencies": {
    "@posthog/react": "^1.9.0",
    "@rectangular-labs/ui": "workspace:*",
    "@t3-oss/env-core": "^0.13.11",
    "@tanstack/react-query": "^5.100.11",
    "@tanstack/react-query-devtools": "^5.100.11",
    "@tanstack/react-router": "^1.170.6",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-router-ssr-query": "^1.167.0",
    "@tanstack/react-start": "^1.168.9",
    "arktype": "^2.2.0",
    "motion": "^12.39.0",
    "posthog-js": "^1.374.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tanstack-router-sitemap": "^1.0.13"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.37.2",
    "@rectangular-labs/typescript": "workspace:*",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "jiti": "^2.7.0",
    "jsdom": "^26.1.0",
    "miniflare": "4.20260518.0",
    "typescript": "^5.9.3",
    "vite": "7.3.3",
    "vite-plugin-mkcert": "^1.17.12",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.7",
    "web-vitals": "^5.2.0",
    "wrangler": "^4.93.0"
  }
}
